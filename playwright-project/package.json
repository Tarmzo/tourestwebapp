{
  "name": "trs-web-automation",
  "version": "1.0.0",
  "by": "Avuyile Malotana",
  "description": "Automation tests for TRS Web Application",
  "scripts": {
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:api": "jest tests/api",
    "test:performance": "jest tests/performance",
    "test:all": "npm run test:api && npm run test:playwright && npm run test:e2e",
    "test:ci": "npm run test:api && npm run test:playwright -- --reporter=junit"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "cypress": "^13.6.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "lighthouse": "^11.4.0",
    "chrome-launcher": "^1.1.0"
  },
  "dependencies": {
    "express": "^4.18.2"
  }
}
